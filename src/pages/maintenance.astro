---
import { PARTNER_EMAIL, REFERRAL_URL } from '../data/referral';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
    <title>Something exceptional is being crafted — Marblism Partners</title>
  </head>
  <body>

    <!-- MARBLE BACKGROUND -->
    <div class="bg" aria-hidden="true">
      <div class="marble-layer ml-1"></div>
      <div class="marble-layer ml-2"></div>
      <div class="marble-layer ml-3"></div>
      <div class="vignette"></div>
    </div>

    <!-- CONTENT -->
    <main class="page">

      <!-- TOP BAR -->
      <header class="top">
        <img src="/logo-light.svg" alt="Marblism Partners" height="28" class="logo" />
        <span class="badge">Private Preview</span>
      </header>

      <!-- CENTRE -->
      <section class="centre">
        <div class="ornament" aria-hidden="true">✦</div>
        <h1>Something exceptional<br /><em>is being crafted.</em></h1>
        <div class="rule"></div>
        <p class="lead">
          We're putting the finishing touches on a new kind of AI experience —
          built for businesses where every detail carries weight.
        </p>
        <p class="sub">
          Be among the first to access Marblism's AI Employees for your business.
        </p>
        <form class="notify-form" action={`https://formspree.io/f/your-formspree-id`} method="POST" data-form>
          <input type="hidden" name="source" value="maintenance-page" />
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hp" />
          <div class="input-row">
            <input
              type="email"
              name="email"
              required
              placeholder="Your email address"
              autocomplete="email"
              class="email-input"
            />
            <button type="submit" class="notify-btn">Notify me</button>
          </div>
          <p class="form-status" data-status aria-live="polite"></p>
        </form>
        <p class="alt">
          Or reach us directly at <a href={`mailto:${PARTNER_EMAIL}`}>{PARTNER_EMAIL}</a>
        </p>
      </section>

      <!-- BOTTOM -->
      <footer class="bottom">
        <div class="bottom-line"></div>
        <div class="bottom-inner">
          <span>© {new Date().getFullYear()} Marblism Partners</span>
          <a href={REFERRAL_URL} target="_blank" rel="noopener">Explore Marblism →</a>
        </div>
      </footer>

    </main>

    <script>
      const form = document.querySelector<HTMLFormElement>('[data-form]');
      const status = document.querySelector<HTMLElement>('[data-status]');
      if (form && status) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = form.querySelector<HTMLButtonElement>('button');
          if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' },
            });
            if (res.ok) {
              form.reset();
              status.textContent = '✓ You\'re on the list. We\'ll be in touch.';
              status.style.color = '#c9a96e';
            } else {
              status.textContent = 'Something went wrong — please email us directly.';
              status.style.color = '#f87171';
            }
          } catch {
            status.textContent = 'Network error — please email us directly.';
            status.style.color = '#f87171';
          } finally {
            if (btn) { btn.disabled = false; btn.textContent = 'Notify me'; }
          }
        });
      }
    </script>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; }

  /* ── MARBLE BACKGROUND ── */
  .bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #08070a;
  }
  .marble-layer {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
  }
  .ml-1 {
    background:
      radial-gradient(ellipse 120% 80% at 10% 20%, rgba(201,169,110,0.13) 0%, transparent 55%),
      radial-gradient(ellipse 80% 60% at 90% 80%, rgba(180,150,90,0.10) 0%, transparent 50%);
  }
  .ml-2 {
    background:
      radial-gradient(ellipse 60% 100% at 80% 10%, rgba(255,255,255,0.04) 0%, transparent 45%),
      radial-gradient(ellipse 40% 70% at 20% 90%, rgba(255,255,255,0.03) 0%, transparent 40%);
  }
  .ml-3 {
    background-image:
      repeating-linear-gradient(
        112deg,
        transparent,
        transparent 38px,
        rgba(201,169,110,0.025) 38px,
        rgba(201,169,110,0.025) 39px
      ),
      repeating-linear-gradient(
        22deg,
        transparent,
        transparent 60px,
        rgba(255,255,255,0.015) 60px,
        rgba(255,255,255,0.015) 61px
      );
  }
  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 40%, rgba(0,0,0,0.70) 100%);
  }

  /* ── LAYOUT ── */
  .page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 36px 24px 32px;
    font-family: 'Inter', system-ui, sans-serif;
    color: #e8e0d0;
    -webkit-font-smoothing: antialiased;
  }

  /* ── TOP ── */
  .top {
    width: 100%;
    max-width: 680px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo { opacity: 0.9; filter: brightness(10); }
  .badge {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c9a96e;
    border: 1px solid rgba(201,169,110,0.30);
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(201,169,110,0.06);
  }

  /* ── CENTRE ── */
  .centre {
    text-align: center;
    max-width: 680px;
    padding: 40px 0;
  }
  .ornament {
    font-size: 1.1rem;
    color: #c9a96e;
    opacity: 0.6;
    margin-bottom: 28px;
    letter-spacing: 0.3em;
  }
  h1 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #f0ebe0;
    margin: 0 0 28px;
  }
  h1 em {
    font-style: italic;
    color: #c9a96e;
    font-weight: 300;
  }
  .rule {
    width: 48px;
    height: 1px;
    background: rgba(201,169,110,0.45);
    margin: 0 auto 28px;
  }
  .lead {
    font-size: 1.08rem;
    color: #b8ad9a;
    line-height: 1.7;
    margin: 0 0 10px;
  }
  .sub {
    font-size: 0.92rem;
    color: #7a7060;
    margin: 0 0 36px;
  }

  /* ── FORM ── */
  .notify-form { width: 100%; max-width: 460px; margin: 0 auto; }
  .input-row {
    display: flex;
    gap: 0;
    border: 1px solid rgba(201,169,110,0.30);
    border-radius: 999px;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    transition: border-color .2s;
  }
  .input-row:focus-within { border-color: rgba(201,169,110,0.65); }
  .email-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 14px 20px;
    font: inherit;
    font-size: 0.95rem;
    color: #f0ebe0;
  }
  .email-input::placeholder { color: #5a5040; }
  .notify-btn {
    background: #c9a96e;
    color: #08070a;
    border: none;
    padding: 14px 22px;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .15s;
    white-space: nowrap;
  }
  .notify-btn:hover { background: #d4b87a; }
  .notify-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-status { margin: 12px 0 0; font-size: 0.88rem; min-height: 1.2em; }
  .hp { position: absolute; left: -9999px; opacity: 0; }
  .alt { margin: 20px 0 0; font-size: 0.85rem; color: #5a5040; }
  .alt a { color: #c9a96e; }
  .alt a:hover { text-decoration: underline; }

  /* ── BOTTOM ── */
  .bottom { width: 100%; max-width: 680px; }
  .bottom-line { height: 1px; background: rgba(255,255,255,0.06); margin-bottom: 18px; }
  .bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.82rem;
    color: #3d3628;
  }
  .bottom-inner a { color: #6a5f48; transition: color .15s; }
  .bottom-inner a:hover { color: #c9a96e; text-decoration: none; }

  @media (max-width: 500px) {
    .badge { display: none; }
    .notify-btn { padding: 14px 16px; font-size: 0.82rem; }
  }
</style>
