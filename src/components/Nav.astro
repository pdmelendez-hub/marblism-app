---
---
<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="Marblism Partners — home">
      <img src="/logo.svg" alt="Marblism Partners" height="32" width="auto" />
    </a>
    <nav aria-label="Primary">
      <div class="dropdown">
        <button class="drop-btn" aria-haspopup="true">Industries ▾</button>
        <div class="drop-menu">
          <a href="/spa">🧖 Spa &amp; Wellness</a>
          <a href="/real-estate">🏘️ Real Estate</a>
          <a href="/travel">✈️ Travel Advisors</a>
          <a href="/office">🗂️ Office Managers</a>
        </div>
      </div>
      <a href="#team">AI Team</a>
      <a href="#contact" class="btn btn-primary nav-cta">Hire your team</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0; z-index: 50;
    background: rgba(255,255,255,0.90);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 15px 24px;
  }
  .brand { display: flex; align-items: center; }
  .brand:hover { text-decoration: none; }
  .brand img { display: block; height: 30px; width: auto; }
  nav { display: flex; align-items: center; }
  nav > a, nav > .dropdown {
    color: var(--ink-2);
    margin-left: 22px;
    font-weight: 500;
    font-size: 0.94rem;
  }
  nav > a:hover { color: var(--ink); text-decoration: none; }

  /* dropdown */
  .dropdown { position: relative; display: inline-block; margin-left: 22px; }
  .drop-btn {
    background: none; border: none; cursor: pointer;
    color: var(--ink-2); font-weight: 500; font-size: 0.94rem;
    padding: 0; font-family: inherit;
    transition: color .15s;
  }
  .drop-btn:hover { color: var(--ink); }
  .drop-menu {
    display: none;
    position: absolute; top: calc(100% + 10px); left: 50%;
    transform: translateX(-50%);
    background: #fff; border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(10,18,36,.12);
    padding: 8px 0; min-width: 210px; z-index: 100;
  }
  .dropdown:hover .drop-menu,
  .dropdown:focus-within .drop-menu { display: block; }
  .drop-menu a {
    display: block; padding: 10px 18px;
    font-size: 0.92rem; color: var(--ink-2); font-weight: 500;
    margin: 0; text-decoration: none;
    transition: background .12s, color .12s;
  }
  .drop-menu a:hover { background: var(--bg-soft); color: var(--ink); text-decoration: none; }

  .nav-cta { color: #fff !important; padding: 10px 18px; font-size: 0.91rem; margin-left: 18px; }
  .nav-cta:hover { color: #fff !important; }

  @media (max-width: 720px) {
    .dropdown, nav > a:not(.nav-cta) { display: none; }
  }
</style>
