---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <a href="/" class="brand">
      <img src="/logo.svg" alt="Marblism Partners" height="24" />
    </a>
    <p class="muted">
      © {year} Marblism Partners. Independent strategic partner — Marblism is a trademark of its respective owners.
    </p>
    <div class="links">
      <a href="mailto:hello@marblism.app">hello@marblism.app</a>
      <a href="https://www.marblism.com" target="_blank" rel="noopener">Marblism platform ↗</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding: 32px 0 56px;
    background: #fff;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
  }
  .brand { display: flex; align-items: center; }
  .brand img { display: block; height: 24px; width: auto; }
  .muted { color: var(--muted); font-size: 0.88rem; margin: 0; }
  .links { display: flex; gap: 18px; font-size: 0.9rem; }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; text-align: left; }
  }
</style>
