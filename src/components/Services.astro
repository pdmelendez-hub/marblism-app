---
const team = [
  {
    name: 'Penny',
    role: 'SEO Blog Writer',
    desc: 'Researches keywords, drafts long-form posts, and ships SEO content that actually ranks — on a schedule.',
    initial: 'P',
    grad: 'linear-gradient(135deg, #f59e0b, #ec4899)',
  },
  {
    name: 'Eva',
    role: 'Executive Assistant',
    desc: 'Triages your inbox, drafts replies in your voice, schedules meetings, and turns calls into clean notes.',
    initial: 'E',
    grad: 'linear-gradient(135deg, #14b8a6, #06b6d4)',
  },
  {
    name: 'Sonny',
    role: 'Community Manager',
    desc: 'Runs your social accounts, replies to DMs, and turns followers into qualified leads — across platforms.',
    initial: 'S',
    grad: 'linear-gradient(135deg, #f97316, #ec4899)',
  },
  {
    name: 'Stan',
    role: 'Lead Generation',
    desc: 'Finds prospects that fit your ICP, drafts personalized outreach, and follows up so nothing slips.',
    initial: 'S',
    grad: 'linear-gradient(135deg, #7c3aed, #3b82f6)',
  },
  {
    name: 'Rachel',
    role: 'Receptionist',
    desc: 'Answers your phone 24/7, qualifies callers, and books appointments straight to your calendar.',
    initial: 'R',
    grad: 'linear-gradient(135deg, #10b981, #14b8a6)',
  },
  {
    name: 'Linda',
    role: 'Legal Assistant',
    desc: 'Reviews contracts, flags risky clauses, and translates legalese into plain English you can act on.',
    initial: 'L',
    grad: 'linear-gradient(135deg, #3b82f6, #7c3aed)',
  },
];
---
<section id="team" class="team">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Meet your AI team</span>
      <h2>Six AI Employees ready to clock in for your business.</h2>
      <p class="section-sub">
        Each one is a Marblism AI Employee — trained, integrated, and tuned to your business.
        Hire one. Hire all six. They don't take vacation.
      </p>
    </div>
    <div class="grid">
      {team.map((t) => (
        <article class="card">
          <div class="avatar" style={`background: ${t.grad}`}>{t.initial}</div>
          <div class="who">
            <h3>{t.name}</h3>
            <span class="role">{t.role}</span>
          </div>
          <p>{t.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team { background: var(--bg-soft); }
  .section-head { max-width: 720px; margin-bottom: 48px; }
  .section-sub { font-size: 1.05rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 28px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(20, 184, 166, 0.30);
  }
  .avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 18px;
    box-shadow: 0 6px 16px rgba(10, 18, 36, 0.12);
  }
  .who { margin-bottom: 12px; }
  .who h3 { margin: 0 0 2px; font-size: 1.25rem; }
  .role {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent-deep);
    background: var(--accent-soft);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .card p { margin: 0; font-size: 0.95rem; }
  @media (max-width: 980px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>
