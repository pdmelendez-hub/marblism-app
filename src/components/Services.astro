---
const services = [
  {
    icon: '🤖',
    title: 'Custom AI Agents',
    desc: 'Always-on agents that answer customers, qualify leads, and handle support with your brand voice.',
  },
  {
    icon: '⚡',
    title: 'Workflow Automation',
    desc: 'Stop pasting between tools. Automate quoting, onboarding, follow-ups, and reporting end-to-end.',
  },
  {
    icon: '🛠️',
    title: 'Custom AI Apps',
    desc: 'Internal dashboards, client portals, and lightweight SaaS — built fast on Marblism.',
  },
  {
    icon: '📈',
    title: 'AI Sales Enablement',
    desc: 'Lead capture, enrichment, outreach, and pipeline insight — your sales team\'s new force multiplier.',
  },
];
---
<section id="services" class="services">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">What we do</span>
      <h2>AI that fits how your business already works.</h2>
      <p class="section-sub">
        We translate your real pain points into AI solutions on the Marblism platform —
        then implement, train, and hand you a system that compounds in value.
      </p>
    </div>
    <div class="grid">
      {services.map((s) => (
        <article class="card">
          <div class="icon">{s.icon}</div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services { background: var(--bg-soft); }
  .section-head { max-width: 720px; margin-bottom: 48px; }
  .section-sub { font-size: 1.05rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 26px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: rgba(91, 91, 247, 0.25);
  }
  .icon {
    font-size: 1.6rem;
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: var(--accent-soft);
    border-radius: 12px;
    margin-bottom: 16px;
  }
  @media (max-width: 980px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>
