---
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <span class="eyebrow">Strategic Marblism Partner</span>
      <h1>AI Employees clock in. <span class="grad">You cash out.</span></h1>
      <p class="lead">
        Put Penny, Eva, Sonny, Stan, Rachel, and Linda to work in your small business.
        They handle calls, content, contracts, leads, and inbox chaos —
        while you focus on the parts only you can do.
      </p>
      <div class="cta-row">
        <a href="#industries" class="btn btn-primary">Find my AI team</a>
        <a href="#team" class="btn btn-ghost">Meet the employees →</a>
      </div>
      <ul class="trust">
        <li>✓ Live in 48 hours</li>
        <li>✓ 7-day money-back guarantee</li>
        <li>✓ No contracts</li>
      </ul>
    </div>
    <div class="art" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="card card-1">
        <div class="avatar a-rachel">R</div>
        <div class="meta">
          <strong>Rachel</strong>
          <span>Booked 4 appointments</span>
        </div>
        <span class="status">●</span>
      </div>
      <div class="card card-2">
        <div class="avatar a-stan">S</div>
        <div class="meta">
          <strong>Stan</strong>
          <span>Sent 12 outreach emails</span>
        </div>
        <span class="status">●</span>
      </div>
      <div class="card card-3">
        <div class="avatar a-eva">E</div>
        <div class="meta">
          <strong>Eva</strong>
          <span>Cleared 47 emails</span>
        </div>
        <span class="status">●</span>
      </div>
      <div class="card card-4">
        <div class="avatar a-penny">P</div>
        <div class="meta">
          <strong>Penny</strong>
          <span>Published 1 blog post</span>
        </div>
        <span class="status">●</span>
      </div>
    </div>
  </div>
</section>

<!-- Social proof strip -->
<div class="proof-strip">
  <div class="container proof-inner">
    <span>🏆 Product Hunt #1</span>
    <span class="sep">·</span>
    <span>40,000+ businesses</span>
    <span class="sep">·</span>
    <span>⭐⭐⭐⭐⭐ rated</span>
    <span class="sep">·</span>
    <span>Live in 48 hours</span>
    <span class="sep">·</span>
    <span>No contracts</span>
  </div>
</div>

<style>
  .hero {
    padding: 96px 0 80px;
    background:
      radial-gradient(60% 60% at 80% 0%, rgba(6, 182, 212, 0.10), transparent 60%),
      radial-gradient(60% 60% at 0% 20%, rgba(20, 184, 166, 0.10), transparent 60%),
      var(--bg);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .grad {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  h1 { font-size: clamp(2rem, 4vw, 2.9rem); line-height: 1.13; margin: 12px 0 0; }
  .lead {
    font-size: 1.12rem;
    color: var(--ink-2);
    max-width: 540px;
    margin-top: 18px;
    line-height: 1.65;
  }
  .cta-row { display: flex; gap: 12px; margin: 28px 0 22px; flex-wrap: wrap; }
  .trust {
    list-style: none;
    padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 18px;
    color: var(--muted); font-size: 0.9rem;
  }
  .art { position: relative; height: 480px; }
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(52px); opacity: .5;
  }
  .orb-1 { width: 260px; height: 260px; background: var(--accent); top: 30px; left: 40px; }
  .orb-2 { width: 220px; height: 220px; background: var(--accent-2); bottom: 40px; right: 20px; }
  .card {
    position: absolute;
    background: #fff; border: 1px solid var(--line);
    border-radius: 16px; box-shadow: var(--shadow-md);
    padding: 13px 15px;
    display: flex; align-items: center; gap: 11px; width: 236px;
  }
  .card-1 { top: 20px;  left: 0; }
  .card-2 { top: 148px; right: 0; }
  .card-3 { top: 276px; left: 30px; }
  .card-4 { bottom: 14px; right: 10px; }
  .avatar {
    width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 0.95rem;
  }
  .a-rachel { background: linear-gradient(135deg, #10b981, #14b8a6); }
  .a-stan   { background: linear-gradient(135deg, #7c3aed, #3b82f6); }
  .a-eva    { background: linear-gradient(135deg, #14b8a6, #06b6d4); }
  .a-penny  { background: linear-gradient(135deg, #f59e0b, #ec4899); }
  .meta { flex: 1; line-height: 1.3; }
  .meta strong { font-size: 0.9rem; color: var(--ink); display: block; }
  .meta span { font-size: 0.76rem; color: var(--muted); }
  .status { color: #10b981; font-size: 0.6rem; flex-shrink: 0; }

  /* proof strip */
  .proof-strip {
    background: var(--accent-soft);
    border-top: 1px solid rgba(20,184,166,.18);
    border-bottom: 1px solid rgba(20,184,166,.18);
    padding: 13px 0;
  }
  .proof-inner {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; flex-wrap: wrap;
    font-size: 0.88rem; font-weight: 500; color: var(--accent-deep);
  }
  .sep { opacity: .35; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .art { height: 320px; }
    .card-3, .card-4 { display: none; }
  }
  @media (max-width: 560px) { .art { display: none; } }
</style>
