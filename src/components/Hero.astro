---
---
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">Strategic Marblism Partner</span>
      <h1>AI that pays for itself, <span class="grad">built for small business</span>.</h1>
      <p class="lead">
        We help small businesses adopt Marblism AI — custom agents, automations, and apps
        that take busywork off your plate, sharpen your sales pipeline, and unlock real growth.
      </p>
      <div class="cta-row">
        <a href="#contact" class="btn btn-primary">Book a free consult</a>
        <a href="#use-cases" class="btn btn-ghost">See use cases →</a>
      </div>
      <ul class="trust">
        <li>✓ No-code &amp; custom builds</li>
        <li>✓ Live in days, not months</li>
        <li>✓ ROI-focused engagements</li>
      </ul>
    </div>
    <div class="art" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="card card-1">
        <div class="card-dot"></div>
        <div class="card-line w-70"></div>
        <div class="card-line w-50"></div>
      </div>
      <div class="card card-2">
        <div class="card-pill">AI Agent</div>
        <div class="card-line w-80"></div>
        <div class="card-line w-60"></div>
        <div class="card-line w-40"></div>
      </div>
      <div class="card card-3">
        <div class="card-bar"><span style="width: 78%"></span></div>
        <div class="card-meta">+78% lead response</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 96px 0 88px;
    background:
      radial-gradient(60% 60% at 80% 0%, rgba(168, 85, 247, 0.10), transparent 60%),
      radial-gradient(60% 60% at 0% 20%, rgba(91, 91, 247, 0.10), transparent 60%),
      var(--bg);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .grad {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lead {
    font-size: 1.15rem;
    color: var(--ink-2);
    max-width: 560px;
    margin-top: 18px;
  }
  .cta-row { display: flex; gap: 12px; margin: 28px 0 22px; flex-wrap: wrap; }
  .trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--muted);
    font-size: 0.92rem;
  }
  .art {
    position: relative;
    height: 460px;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.5;
  }
  .orb-1 { width: 280px; height: 280px; background: var(--accent); top: 20px; left: 30px; }
  .orb-2 { width: 240px; height: 240px; background: var(--accent-2); bottom: 30px; right: 10px; }
  .card {
    position: absolute;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 16px;
  }
  .card-1 { top: 30px; left: 0; width: 220px; }
  .card-2 { top: 130px; right: 0; width: 240px; }
  .card-3 { bottom: 20px; left: 60px; width: 240px; }
  .card-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    margin-bottom: 12px;
  }
  .card-line {
    height: 8px; border-radius: 4px;
    background: var(--bg-soft);
    margin: 6px 0;
  }
  .w-40 { width: 40%; } .w-50 { width: 50%; } .w-60 { width: 60%; } .w-70 { width: 70%; } .w-80 { width: 80%; }
  .card-pill {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 10px;
  }
  .card-bar {
    height: 8px; background: var(--bg-soft); border-radius: 4px; overflow: hidden;
  }
  .card-bar span {
    display: block; height: 100%;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
  }
  .card-meta { margin-top: 8px; font-size: 0.85rem; color: var(--ink-2); font-weight: 600; }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .art { height: 360px; }
  }
</style>
