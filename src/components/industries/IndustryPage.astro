---
import Layout from '../../layouts/Layout.astro';
import { REFERRAL_URL, PARTNER_EMAIL } from '../../data/referral';

export interface Employee {
  name: string;
  role: string;
  fit: string;
  grad: string;
}

export interface Pain {
  before: string;
  after: string;
}

export interface Props {
  industry: string;
  tagline: string;
  subhead: string;
  employees: Employee[];
  pains: Pain[];
  cta: string;
  icon?: string;
  seoTitle?: string;
  seoDesc?: string;
}

const {
  industry,
  tagline,
  subhead,
  employees,
  pains,
  cta,
  icon = '✦',
  seoTitle,
  seoDesc,
} = Astro.props;
---
<Layout
  title={seoTitle ?? `${industry} AI Employees — Marblism Partners`}
  description={seoDesc ?? `AI employees built for ${industry.toLowerCase()} owners. ${tagline}`}
>

  <!-- NAV -->
  <header class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand" aria-label="Home">
        <img src="/logo.svg" alt="Marblism Partners" height="28" />
      </a>
      <div class="nav-actions">
        <a href="/#industries" class="back">← All industries</a>
        <a href={REFERRAL_URL} class="btn btn-primary" target="_blank" rel="noopener">Get started free</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="eyebrow-row">
          <span class="ind-icon">{icon}</span>
          <span class="eyebrow">{industry}</span>
        </div>
        <h1 set:html={tagline} />
        <p class="lead">{subhead}</p>
        <div class="cta-row">
          <a href={REFERRAL_URL} class="btn btn-primary" target="_blank" rel="noopener">{cta}</a>
          <a href={`mailto:${PARTNER_EMAIL}`} class="btn btn-ghost">Get a free AI audit →</a>
        </div>
        <ul class="trust">
          <li>✓ Live in 48 hours</li>
          <li>✓ 7-day money-back guarantee</li>
          <li>✓ No contracts</li>
        </ul>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="orb"></div>
        {employees.slice(0, 3).map((e, i) => (
          <div class={`card card-${i + 1}`}>
            <div class="avatar" style={`background: ${e.grad}`}>{e.name[0]}</div>
            <div class="meta">
              <strong>{e.name}</strong>
              <span>{e.role}</span>
            </div>
            <span class="dot">●</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF STRIP -->
  <div class="proof-strip">
    <div class="container proof-inner">
      <span>🏆 Product Hunt #1</span>
      <span class="sep">·</span>
      <span>40,000+ businesses using Marblism</span>
      <span class="sep">·</span>
      <span>⭐⭐⭐⭐⭐ rated</span>
      <span class="sep">·</span>
      <span>Live in 48 hours</span>
    </div>
  </div>

  <!-- AI TEAM -->
  <section class="team">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Your AI team</span>
        <h2>The employees who clock in for your {industry.toLowerCase()} business.</h2>
        <p class="section-sub">Each one is a Marblism AI Employee — trained on your business, integrated with your tools, and tuned to your tone. Hire one. Hire all. They don't take lunch breaks.</p>
      </div>
      <div class="emp-grid">
        {employees.map((e) => (
          <article class="emp-card">
            <div class="emp-avatar" style={`background: ${e.grad}`}>{e.name[0]}</div>
            <div class="emp-body">
              <div class="emp-who">
                <h3>{e.name}</h3>
                <span class="role-badge">{e.role}</span>
              </div>
              <p>{e.fit}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="ba">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What actually changes</span>
        <h2>The first 30 days with your AI team.</h2>
        <p class="section-sub">Not hypothetical outcomes. Specific tasks that get handled, every day, without you doing them.</p>
      </div>
      <div class="ba-wrap">
        <div class="ba-col ba-before">
          <div class="ba-label">❌ Before</div>
          {pains.map((p) => (
            <div class="ba-row">{p.before}</div>
          ))}
        </div>
        <div class="ba-arrow" aria-hidden="true">→</div>
        <div class="ba-col ba-after">
          <div class="ba-label">✓ After</div>
          {pains.map((p) => (
            <div class="ba-row">{p.after}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">How it works</span>
        <h2>From "what is this?" to "how did I run without it?" in three steps.</h2>
      </div>
      <ol class="steps">
        <li class="step">
          <div class="step-num">01</div>
          <h3>Free discovery call</h3>
          <p>30 minutes. We map your biggest time drains to the right AI Employees and show you exactly what to expect.</p>
        </li>
        <li class="step">
          <div class="step-num">02</div>
          <h3>We onboard your team</h3>
          <p>We set up your AI Employees on Marblism, train them on your tone and tools, and integrate everything you already use.</p>
        </li>
        <li class="step">
          <div class="step-num">03</div>
          <h3>They clock in, you cash out</h3>
          <p>Your AI team runs in the background. We tune, you run your business. Most owners recover the cost in week one.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>Ready to hire your {industry.toLowerCase()} AI team?</h2>
        <p>Start your free trial through my partner link. I'll onboard your team personally — no extra charge. 7-day guarantee, no contracts.</p>
      </div>
      <div class="cta-btns">
        <a href={REFERRAL_URL} class="btn btn-white" target="_blank" rel="noopener">{cta} →</a>
        <a href={`mailto:${PARTNER_EMAIL}`} class="btn btn-outline-light">Email us first</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <a href="/"><img src="/logo.svg" alt="Marblism Partners" height="22" /></a>
      <p>© {new Date().getFullYear()} Marblism Partners — Independent strategic partner. Marblism is a trademark of its respective owners.</p>
      <div class="links">
        <a href="/#industries">All industries</a>
        <a href="mailto:hello@marblism.app">hello@marblism.app</a>
        <a href={REFERRAL_URL} target="_blank" rel="noopener">Get Marblism ↗</a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ── NAV ─────────────────────────────────────────────── */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255,255,255,0.92);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; }
  .brand img { display: block; height: 28px; }
  .nav-actions { display: flex; align-items: center; gap: 20px; }
  .back { font-size: 0.9rem; color: var(--muted); font-weight: 500; transition: color .15s; }
  .back:hover { color: var(--ink); text-decoration: none; }

  /* ── HERO ────────────────────────────────────────────── */
  .hero {
    padding: 88px 0 80px;
    background:
      radial-gradient(55% 55% at 85% 10%, rgba(20,184,166,.10), transparent 60%),
      radial-gradient(40% 40% at 5% 60%, rgba(6,182,212,.07), transparent 60%),
      var(--bg);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .eyebrow-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .ind-icon { color: var(--accent); font-size: 1rem; }
  .eyebrow { margin: 0; }
  h1 { font-size: clamp(1.9rem, 3.8vw, 2.75rem); line-height: 1.15; margin: 0 0 18px; }
  .lead { font-size: 1.08rem; color: var(--ink-2); max-width: 540px; margin: 0 0 26px; line-height: 1.65; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
  .trust { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 16px; font-size: 0.88rem; color: var(--muted); }

  /* hero art */
  .hero-art { position: relative; height: 400px; }
  .orb {
    position: absolute; width: 280px; height: 280px; border-radius: 50%;
    background: radial-gradient(circle, rgba(20,184,166,.18), transparent 70%);
    top: 30px; left: 20px; filter: blur(32px);
  }
  .card {
    position: absolute;
    background: #fff; border: 1px solid var(--line);
    border-radius: 14px; box-shadow: var(--shadow-md);
    padding: 13px 15px;
    display: flex; align-items: center; gap: 11px; width: 226px;
  }
  .card-1 { top: 18px; left: 0; }
  .card-2 { top: 160px; right: 0; }
  .card-3 { bottom: 20px; left: 44px; }
  .avatar {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 0.95rem;
  }
  .meta { flex: 1; line-height: 1.3; }
  .meta strong { font-size: 0.9rem; color: var(--ink); display: block; }
  .meta span { font-size: 0.76rem; color: var(--muted); }
  .dot { font-size: 0.55rem; color: #10b981; flex-shrink: 0; }

  /* ── PROOF STRIP ─────────────────────────────────────── */
  .proof-strip {
    background: var(--accent-soft);
    border-top: 1px solid rgba(20,184,166,.2);
    border-bottom: 1px solid rgba(20,184,166,.2);
    padding: 14px 0;
  }
  .proof-inner {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; flex-wrap: wrap;
    font-size: 0.88rem; font-weight: 500; color: var(--accent-deep);
  }
  .sep { opacity: 0.35; }

  /* ── TEAM ────────────────────────────────────────────── */
  .team { background: var(--bg-soft); padding: 80px 0; }
  .section-head { max-width: 680px; margin-bottom: 44px; }
  .section-sub { font-size: 1rem; color: var(--ink-2); margin-top: 10px; }
  .emp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .emp-card {
    background: #fff; border: 1px solid var(--line);
    border-radius: var(--radius); padding: 24px;
    display: flex; gap: 16px; align-items: flex-start;
    transition: transform .2s, box-shadow .2s, border-color .2s;
  }
  .emp-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: rgba(20,184,166,.3); }
  .emp-avatar {
    width: 48px; height: 48px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 1.2rem;
    box-shadow: 0 4px 12px rgba(10,18,36,.12);
  }
  .emp-body { flex: 1; }
  .emp-who { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
  .emp-who h3 { margin: 0; font-size: 1.08rem; }
  .role-badge {
    font-size: 0.72rem; font-weight: 600; color: var(--accent-deep);
    background: var(--accent-soft); padding: 3px 9px; border-radius: 999px;
  }
  .emp-card p { margin: 0; font-size: 0.92rem; color: var(--ink-2); line-height: 1.55; }

  /* ── BEFORE / AFTER ──────────────────────────────────── */
  .ba { padding: 80px 0; }
  .ba-wrap { display: flex; gap: 12px; align-items: flex-start; margin-top: 40px; }
  .ba-col { flex: 1; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); }
  .ba-label {
    padding: 13px 20px; font-size: 0.78rem; text-transform: uppercase;
    letter-spacing: .1em; font-weight: 700;
  }
  .ba-before .ba-label { background: #f1f4f8; color: var(--muted); }
  .ba-after  .ba-label { background: var(--accent-soft); color: var(--accent-deep); }
  .ba-row {
    padding: 14px 20px; border-bottom: 1px solid var(--line);
    font-size: 0.92rem; line-height: 1.5; color: var(--ink-2);
  }
  .ba-row:last-child { border-bottom: none; }
  .ba-before .ba-row { background: #f9fafc; color: var(--muted); }
  .ba-after  .ba-row { background: #f0fdf8; color: var(--ink); font-weight: 500; }
  .ba-arrow { font-size: 1.6rem; color: var(--accent); opacity: .4; padding-top: 50px; flex-shrink: 0; }

  /* ── HOW IT WORKS ────────────────────────────────────── */
  .how { background: var(--bg-soft); padding: 80px 0; }
  .steps {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .step {
    background: #fff; border: 1px solid var(--line);
    border-radius: var(--radius); padding: 30px;
  }
  .step-num {
    font-size: 1.3rem; font-weight: 800; margin-bottom: 12px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .step h3 { margin: 0 0 8px; font-size: 1.05rem; }
  .step p { margin: 0; font-size: 0.93rem; color: var(--ink-2); }

  /* ── CTA STRIP ───────────────────────────────────────── */
  .cta-strip {
    background: linear-gradient(135deg, #061a23 0%, #0c2d3a 100%);
    padding: 72px 0; color: #fff;
  }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .cta-text h2 { color: #fff; margin: 0 0 10px; font-size: 1.75rem; }
  .cta-text p { color: #cfe8ec; margin: 0; font-size: 1rem; max-width: 500px; line-height: 1.6; }
  .cta-btns { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }

  .btn-white {
    background: #fff; color: var(--ink) !important;
    border: 2px solid #fff; border-radius: 10px; padding: 12px 22px;
    font-weight: 700; font-size: 0.95rem; display: inline-block;
    text-decoration: none; transition: background .15s, transform .15s;
  }
  .btn-white:hover { background: #e8f9f7; transform: translateY(-1px); text-decoration: none; }
  .btn-outline-light {
    background: transparent; color: #cfe8ec !important;
    border: 1.5px solid rgba(255,255,255,.3); border-radius: 10px; padding: 12px 22px;
    font-weight: 600; font-size: 0.95rem; display: inline-block;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .btn-outline-light:hover { border-color: rgba(255,255,255,.7); color: #fff !important; text-decoration: none; }

  /* ── FOOTER ──────────────────────────────────────────── */
  .footer { border-top: 1px solid var(--line); padding: 28px 0 48px; }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .footer-inner img { display: block; height: 22px; }
  .footer-inner p { margin: 0; font-size: 0.82rem; color: var(--muted); }
  .links { display: flex; gap: 18px; font-size: 0.88rem; }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 880px) {
    .hero-inner { grid-template-columns: 1fr; gap: 0; }
    .hero-art { display: none; }
  }
  @media (max-width: 760px) {
    .ba-wrap { flex-direction: column; }
    .ba-arrow { display: none; }
    .ba-col { width: 100%; }
    .steps { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; text-align: center; }
    .cta-btns { justify-content: center; }
    .footer-inner { flex-direction: column; }
    .nav-actions .back { display: none; }
  }
</style>
