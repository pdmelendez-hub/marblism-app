---
export interface Props {
  title?: string;
  description?: string;
  accent?: string;
}

const {
  title = 'Luxury AI Solutions — Marblism Partners',
  description = 'AI employees built for businesses where reputation is everything. White-glove implementation, powered by Marblism.',
  accent = '#c9a96e',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <style is:global define:vars={{ accent }}>
      :root {
        --lx-bg: #09090f;
        --lx-bg-2: #111118;
        --lx-bg-3: #18181f;
        --lx-gold: var(--accent);
        --lx-gold-soft: rgba(201, 169, 110, 0.12);
        --lx-gold-line: rgba(201, 169, 110, 0.20);
        --lx-white: #f5f2ec;
        --lx-white-2: #b8b0a0;
        --lx-muted: #6a6460;
        --lx-line: rgba(255,255,255,0.07);
        --lx-radius: 12px;
        --lx-shadow: 0 12px 40px rgba(0,0,0,0.50), 0 2px 8px rgba(0,0,0,0.30);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: var(--lx-bg);
        color: var(--lx-white);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--lx-gold); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin: 0 0 0.4em;
      }
      h1 { font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 600; }
      h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 600; }
      h3 { font-size: 1.3rem; font-weight: 600; }
      p { margin: 0 0 1em; color: var(--lx-white-2); }
      .container { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
      .btn {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.92rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
        cursor: pointer;
        border: 1px solid transparent;
      }
      .btn-gold {
        background: var(--lx-gold);
        color: #09090f;
        box-shadow: 0 4px 20px rgba(201,169,110,0.35);
      }
      .btn-gold:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(201,169,110,0.45); text-decoration: none; }
      .btn-outline {
        background: transparent;
        border-color: var(--lx-gold-line);
        color: var(--lx-gold);
      }
      .btn-outline:hover { background: var(--lx-gold-soft); text-decoration: none; border-color: var(--lx-gold); }
      .eyebrow {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--lx-gold);
        margin-bottom: 16px;
      }
      section { padding: 96px 0; }
      .divider {
        width: 48px; height: 1px;
        background: var(--lx-gold);
        opacity: 0.5;
        margin: 20px 0 32px;
      }
      @media (max-width: 720px) { section { padding: 64px 0; } }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
